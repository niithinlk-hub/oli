{
  "name": "oli",
  "version": "1.1.0",
  "description": "Oli — local-first AI meeting memory for Windows.",
  "main": "out/main/index.js",
  "author": "hussa",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "postinstall": "node native/win-loopback/scripts/postinstall.cjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win",
    "package:nsis": "electron-vite build && electron-builder --win nsis",
    "publish": "electron-vite build && electron-builder --win --publish always",
    "native:build": "npm --prefix native/win-loopback run build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "better-sqlite3": "^11.5.0",
    "cmdk": "^1.1.1",
    "dompurify": "^3.2.3",
    "electron-updater": "^6.3.9",
    "groq-sdk": "^1.1.2",
    "marked": "^15.0.4",
    "node-ical": "^0.20.1",
    "openai": "^4.73.0",
    "react-resizable-panels": "^2.1.9",
    "turndown": "^7.2.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "ai.oli.app",
    "productName": "Oli",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "native/win-loopback/index.cjs",
      "native/win-loopback/package.json",
      "native/win-loopback/*.node",
      "resources/icons/**",
      "resources/whisper-bin/**",
      "!resources/whisper-models/**",
      "package.json"
    ],
    "asarUnpack": [
      "native/win-loopback/*.node",
      "resources/whisper-bin/**",
      "resources/icons/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/oli.png",
      "artifactName": "Oli-${version}-Setup.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Oli"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "niithinlk-hub",
        "repo": "oli",
        "releaseType": "draft"
      }
    ]
  }
}
